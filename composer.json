{
  "name": "elriseio/application-layer-bundle",
  "description": "Emphasizes that this is the Application Layer, not tied to the API specifics or any particular domain.",
  "type": "symfony-bundle",
  "license": "MIT",
  "keywords": [
    "symfony",
    "symfony-bundle",
    "cqrs",
    "ddd",
    "application-layer",
    "dto",
    "messenger"
  ],
  "homepage": "https://github.com/elriseio/application-layer-bundle",
  "support": {
    "issues": "https://github.com/elriseio/application-layer-bundle/issues",
    "source": "https://github.com/elriseio/application-layer-bundle",
    "docs": "https://github.com/elriseio/application-layer-bundle#readme"
  },
  "authors": [
    {
      "name": "AlexK",
      "email": "alexk@elrise.io"
    }
  ],
  "require": {
    "php": "~8.3",
    "ext-ctype": "*",
    "ext-curl": "*",
    "ext-json": "*",
    "doctrine/annotations": "^2.0",
    "symfony/config": "^7.2",
    "symfony/dependency-injection": "^7.2",
    "symfony/http-client": "^7.2",
    "symfony/http-foundation": "^7.2",
    "symfony/http-kernel": "^7.2",
    "symfony/intl": "^7.2",
    "symfony/polyfill-intl-icu": "^1.31",
    "symfony/property-access": "^7.2",
    "symfony/serializer": "^7.2",
    "symfony/validator": "^7.2",
    "symfony/yaml": "^7.2"
  },
  "autoload": {
    "psr-4": {
      "Elrise\\Bundle\\AppLayerBundle\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Elrise\\Bundle\\AppLayerBundle\\Tests\\": "tests/"
    }
  },
  "config": {
    "sort-packages": true
  },
  "require-dev": {
    "phpunit/phpunit": "^12.0",
    "friendsofphp/php-cs-fixer": "^3.74",
    "symfony/messenger": "^7.2"
  },
  "scripts": {
    "cs:fix": "@php vendor/bin/php-cs-fixer fix",
    "cs:check": "@php vendor/bin/php-cs-fixer fix --dry-run --diff",
    "test": "@php vendor/bin/phpunit",
    "check": [
      "@cs:check",
      "@test"
    ]
  },
  "extra": {
    "branch-alias": {
      "dev-main": "1.x-dev"
    }
  },
  "suggest": {
    "symfony/messenger": "Required to enable async queueing via DtoQueueDispatcherInterface"
  }
}
